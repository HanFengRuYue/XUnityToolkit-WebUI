<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="XUnityToolkit-WebUI"
           Manufacturer="XUnityToolkit"
           Version="$(var.MsiVersion)"
           UpgradeCode="E8A3F4B2-7C1D-4E5A-9B6F-2D8C4A1E3F7B"
           Compressed="yes"
           InstallerVersion="500"
           Scope="perUser">

    <SummaryInformation Description="XUnityToolkit-WebUI Installer" />

    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of XUnityToolkit-WebUI is already installed. Downgrade is not supported." />

    <MediaTemplate EmbedCab="yes" CompressionLevel="medium" />

    <Icon Id="AppIcon" SourceFile="$(var.PublishDir)\XUnityToolkit-WebUI.exe" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/XUnityToolkit/XUnityToolkit-WebUI" />

    <Feature Id="ProductFeature" Title="XUnityToolkit-WebUI" Level="1">
      <ComponentGroupRef Id="CoreComponents" />
      <ComponentGroupRef Id="ShortcutComponents" />
      <ComponentGroupRef Id="HarvestedFiles" />
      <ComponentGroupRef Id="CleanupComponents" />
    </Feature>

    <!-- Install wizard UI (Welcome -> License -> Directory -> Install -> Finish) -->
    <ui:WixUI Id="WixUI_InstallDir" />

    <!-- Custom license file (overrides default WixUI Lorem Ipsum placeholder) -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!-- Bind directory chooser to INSTALLDIR -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />

    <!-- Launch-after-install checkbox on ExitDialog (default checked) -->
    <!-- Chinese text via !(loc.) to avoid MSI codepage 1252 WIX0311 error -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="!(loc.LaunchCheckboxText)" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <Property Id="WixShellExecTarget" Value="[INSTALLDIR]XUnityToolkit-WebUI.exe" />
    <CustomAction Id="LaunchApplication"
                  DllEntry="WixShellExec"
                  Impersonate="yes"
                  BinaryRef="Wix4UtilCA_X86" />

    <!-- Wire ExitDialog Finish button to launch action when checkbox is checked -->
    <UI>
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchApplication"
               Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed" />
    </UI>

  </Package>
</Wix>
