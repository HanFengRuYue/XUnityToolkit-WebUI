<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <ComponentGroup Id="CleanupComponents" Directory="INSTALLDIR">
      <Component Id="CleanupAppData" Guid="D4E5F6A7-B8C9-0123-DEF0-456789ABCDEF">
        <RegistryValue Root="HKCU" Key="Software\XUnityToolkit"
                       Name="CleanupMarker" Type="integer" Value="1" KeyPath="yes" />
        <!-- RemoveFolderEx intentionally removed: user data in %AppData%\XUnityToolkit\
             is preserved on uninstall (industry standard). Component shell with same GUID
             is kept for MSI reference counting during MajorUpgrade from older versions. -->
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
