<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <UI>
      <Dialog Id="UninstallConfirmDlg" Width="370" Height="270"
              Title="[ProductName]">

        <!-- Banner (matches built-in dialog style, WixUI_Bmp_Banner from WixUI extension) -->
        <Control Id="BannerBitmap" Type="Bitmap"
                 X="0" Y="0" Width="370" Height="44"
                 TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line"
                 X="0" Y="44" Width="370" Height="0" />

        <Control Id="Title" Type="Text"
                 X="15" Y="6" Width="200" Height="15"
                 Transparent="yes" NoPrefix="yes"
                 Text="{\WixUI_Font_Title}!(loc.UninstallConfirmTitle)" />
        <Control Id="Description" Type="Text"
                 X="25" Y="23" Width="340" Height="20"
                 Transparent="yes" NoPrefix="yes"
                 Text="!(loc.UninstallConfirmSubtitle)" />

        <!-- Body text -->
        <Control Id="BodyText" Type="Text"
                 X="25" Y="60" Width="320" Height="40"
                 NoPrefix="yes"
                 Text="!(loc.UninstallConfirmBody)" />

        <!-- Checkbox: delete user data -->
        <Control Id="DeleteDataCheckbox" Type="CheckBox"
                 X="25" Y="110" Width="320" Height="18"
                 Property="DELETE_USER_DATA"
                 CheckBoxValue="1"
                 Text="!(loc.UninstallConfirmDeleteCheckbox)" />

        <!-- Data path hint (smaller text) -->
        <Control Id="DataPathHint" Type="Text"
                 X="40" Y="130" Width="305" Height="15"
                 NoPrefix="yes"
                 Text="!(loc.UninstallConfirmDataPathHint)" />

        <!-- Warning text -->
        <Control Id="WarningText" Type="Text"
                 X="40" Y="148" Width="305" Height="30"
                 NoPrefix="yes"
                 Text="!(loc.UninstallConfirmWarning)" />

        <!-- Bottom line -->
        <Control Id="BottomLine" Type="Line"
                 X="0" Y="234" Width="370" Height="0" />

        <!-- Back button: reset both navigation and checkbox properties -->
        <Control Id="Back" Type="PushButton"
                 X="180" Y="243" Width="56" Height="17"
                 Text="!(loc.WixUIBack)">
          <Publish Property="DELETE_USER_DATA" Value="{}" Order="1" />
          <Publish Property="WIXUI_REMOVING" Value="{}" Order="2" />
          <Publish Event="NewDialog" Value="MaintenanceTypeDlg" Order="3" />
        </Control>

        <!-- Remove button -->
        <Control Id="Remove" Type="PushButton"
                 X="242" Y="243" Width="56" Height="17"
                 Default="yes"
                 Text="!(loc.UninstallConfirmRemoveButton)">
          <Publish Property="WIXUI_REMOVING" Value="1" Order="1" />
          <Publish Event="NewDialog" Value="VerifyReadyDlg" Order="2" />
        </Control>

        <!-- Cancel button -->
        <Control Id="Cancel" Type="PushButton"
                 X="304" Y="243" Width="56" Height="17"
                 Cancel="yes"
                 Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>

      </Dialog>
    </UI>
  </Fragment>
</Wix>
